{
  "name": "youdaonote-pull",
  "version": "1.0.0",
  "description": "有道云笔记导出工具 - TypeScript/Bun 版本",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "compile": "bun build src/index.ts --compile --outfile dist/youdaonote-pull"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.1",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/turndown": "^5.0.5",
    "typescript": "^5.7.0"
  }
}
